PORT=10000
NODE_ENV=production

# Admin account (created automatically on first boot)
ADMIN_NAME=System Admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=YourStrongPassword@123

# PostgreSQL (use Render Internal Database URL values)
DB_HOST=your-render-db-host.render.com
DB_PORT=5432
DB_NAME=milta_prm
DB_USER=milta_prm_user
DB_PASSWORD=your-db-password

# JWT — generate a strong random string (64+ chars)
JWT_SECRET=replace-with-a-long-random-secret-string

# URLs
BASE_URL=https://your-render-service.onrender.com

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.vercel.app

# SMTP Email (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Milta PRM <your-email@gmail.com>
